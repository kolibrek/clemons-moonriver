---
const { name, image, quote } = Astro.props;
---

<article>
  <div class="icon"></div>
  <h1>{name}</h1>
  <p>"{quote}"</p>
</article>

<style>
  article {
    display: grid;
    align-items: center;
    row-gap: 1rem;
    border: 1px solid #ccc;
    border-radius: 0.5rem;
    padding: 1rem;
    box-shadow: 0px 0px 20px #0006;
    grid-template-areas:
      "a b"
      "c c";
  }
  .icon {
    grid-area: a;
		background-color: #333;
		border-radius: 100%;
		height: 64px;
		width: 64px;
	}
  h1 {
    grid-area: b;
  }
  p {
    grid-area: c;
    font-style: italic;
  }
</style>